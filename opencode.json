{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-opus-4-5",
  "provider": {
    "anthropic": {
      "apiKey": "{env:ANTHROPIC_API_KEY}"
    }
  },
  "mcp": {
    "ffmpeg": {
      "type": "local",
      "command": ["node", "mcp-servers/ffmpeg-server/index.js"]
    },
    "whisperx": {
      "type": "local",
      "command": ["python", "mcp-servers/whisperx-server/server.py"]
    },
    "media-gen": {
      "type": "local",
      "command": ["python", "mcp-servers/media-gen-server/server.py"]
    }
  },
  "instructions": ["CLAUDE.md"]
}
